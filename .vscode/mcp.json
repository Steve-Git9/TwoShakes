{
  "servers": {
    "dataprepagent": {
      "command": "python",
      "args": ["${workspaceFolder}/src/mcp_server.py"],
      "env": {
        "AZURE_AI_PROJECT_ENDPOINT": "${env:AZURE_AI_PROJECT_ENDPOINT}",
        "AZURE_AI_PROJECT_KEY": "${env:AZURE_AI_PROJECT_KEY}",
        "AZURE_AI_MODEL_DEPLOYMENT_NAME": "${env:AZURE_AI_MODEL_DEPLOYMENT_NAME}",
        "AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT": "${env:AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT}",
        "AZURE_DOCUMENT_INTELLIGENCE_KEY": "${env:AZURE_DOCUMENT_INTELLIGENCE_KEY}"
      }
    }
  }
}
